#!/usr/bin/env bash

set -euo pipefail

battery_status() {
    local bat
    for bat in /sys/class/power_supply/BAT*; do
        [[ -d "$bat" ]] || continue
        local capacity status icon
        capacity="$(<"$bat/capacity" 2>/dev/null || echo "?")"
        status="$(<"$bat/status" 2>/dev/null || echo "?")"
        case "$status" in
            Charging) icon="+" ;;
            Discharging) icon="-" ;;
            Full) icon="=" ;;
            *) icon="?" ;;
        esac
        printf 'bat %s%%%s' "$capacity" "$icon"
        return 0
    done
    printf 'bat n/a'
}

network_status() {
    local iface ip ssid
    iface="$(ip route get 1.1.1.1 2>/dev/null | awk '/dev/ {for (i = 1; i <= NF; i++) if ($i == "dev") {print $(i+1); exit}}')"
    ip="$(ip route get 1.1.1.1 2>/dev/null | awk '/src/ {for (i = 1; i <= NF; i++) if ($i == "src") {print $(i+1); exit}}')"
    if [[ -z "${iface:-}" ]]; then
        printf 'net offline'
        return 0
    fi
    if command -v iw >/dev/null 2>&1; then
        ssid="$(iw dev "$iface" link 2>/dev/null | sed -n 's/^\tSSID: //p' | head -n1)"
    else
        ssid=""
    fi
    if [[ -n "$ssid" ]]; then
        printf 'net %s:%s' "$iface" "$ssid"
    elif [[ -n "${ip:-}" ]]; then
        printf 'net %s:%s' "$iface" "$ip"
    else
        printf 'net %s' "$iface"
    fi
}

render() {
    printf '\033[H\033[2J'
    printf '%s | %s | sess Alt+w list Alt+W home\n' "$(battery_status)" "$(network_status)"
    printf 'tabs Alt+1..6 Alt+, Alt+. Alt+q close | panes Alt+h/j/k/l Alt+n Alt+x | tools Alt+e/g/m/s\n'
}

trap 'printf "\033[?25h"' EXIT
printf '\033[?25l'

while true; do
    render
    sleep 5
done
