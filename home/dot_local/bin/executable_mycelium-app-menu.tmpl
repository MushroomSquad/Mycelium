#!/usr/bin/env bash

set -euo pipefail

if [[ -z "${ZELLIJ:-}" ]]; then
    printf 'mycelium-app-menu: not running inside zellij\n' >&2
    exit 1
fi

launcher="${HOME}/.local/bin/mycelium-open-tab"

options=(
    "edit:Code: Neovim editor"
    "git:Git: Lazygit UI"
    "monitor:System: btop monitor"
    "logs:System: journal logs"
    "telegram:Chat: Telegram via tgt"
    "spotify:Music: Spotify Player"
    "newsboat:News: RSS via Newsboat"
    "aerc:Mail: Aerc client"
    "neomutt:Mail: NeoMutt client"
    "yazi:Files: Yazi preview manager"
    "ranger:Files: Ranger browser"
    "nnn:Files: nnn minimal manager"
    "ncdu:Disk: ncdu usage viewer"
    "broot:Disk: broot tree explorer"
    "w3m:Web: w3m text browser"
    "lynx:Web: Lynx classic browser"
    "cmus:Music: cmus local player"
    "shell:Shell: new terminal tab"
)

pick=""
if command -v fzf >/dev/null 2>&1; then
    pick="$(
        printf '%s\n' "${options[@]}" |
            fzf --height=70% --reverse --prompt="app tab: " --with-nth=2
    )"
else
    printf '\033[H\033[2J'
    printf 'Open tab:\n\n'
    local_index=1
    for option in "${options[@]}"; do
        printf ' %2d. %s\n' "$local_index" "${option#*:}"
        local_index=$((local_index + 1))
    done
    printf '\nSelect number: '
    read -r reply < /dev/tty || true
    if [[ "$reply" =~ ^[0-9]+$ ]] && (( reply >= 1 && reply <= ${#options[@]} )); then
        pick="${options[$((reply - 1))]}"
    fi
fi

[[ -n "$pick" ]] || exit 0
exec "$launcher" "${pick%%:*}"
