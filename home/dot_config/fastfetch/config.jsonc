{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "padding": { "top": 1, "right": 2 }
  },
  "display": {
    "separator": "  "
  },
  "modules": [
    "break",
    {
      "type": "title",
      "color": { "user": "green", "at": "#7f849c", "host": "blue" }
    },
    {
      "type": "os",
      "key": "os",
      "keyColor": "magenta"
    },
    {
      "type": "kernel",
      "key": "kernel",
      "keyColor": "magenta"
    },
    {
      "type": "shell",
      "key": "shell",
      "keyColor": "magenta"
    },
    {
      "type": "terminal",
      "key": "terminal",
      "keyColor": "magenta"
    },
    {
      "type": "wm",
      "format": "tty + zellij",
      "key": "workspace",
      "keyColor": "magenta"
    },
    {
      "type": "cpu",
      "key": "cpu",
      "keyColor": "magenta"
    },
    {
      "type": "memory",
      "key": "memory",
      "keyColor": "magenta"
    },
    {
      "type": "disk",
      "key": "disk",
      "keyColor": "magenta"
    },
    {
      "type": "battery",
      "key": "battery",
      "keyColor": "magenta"
    },
    "break",
    {
      "type": "colors",
      "paddingLeft": 2
    }
  ]
}
