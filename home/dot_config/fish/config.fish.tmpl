# Mycelium managed — do not edit manually
# Profile: {{ .profile }}

# --- PATH ---
fish_add_path -gP ~/.cargo/bin ~/.local/bin

# --- Console palette (Catppuccin Mocha on bare TTY) ---
if test "$TERM" = "linux"
    # Remap the 16 console colors to Catppuccin Mocha
    printf '\e]P01e1e2e'  # black      → Base
    printf '\e]P1f38ba8'  # red        → Red
    printf '\e]P2a6e3a1'  # green      → Green
    printf '\e]P3f9e2af'  # yellow     → Yellow
    printf '\e]P489b4fa'  # blue       → Blue
    printf '\e]P5f5c2e7'  # magenta    → Pink
    printf '\e]P689dceb'  # cyan       → Teal
    printf '\e]P7bac2de'  # white      → Subtext1
    printf '\e]P8585b70'  # bright black  → Surface2
    printf '\e]P9f38ba8'  # bright red    → Red
    printf '\e]PAa6e3a1'  # bright green  → Green
    printf '\e]PBf9e2af'  # bright yellow → Yellow
    printf '\e]PC89b4fa'  # bright blue   → Blue
    printf '\e]PDcba6f7'  # bright magenta → Mauve
    printf '\e]PE94e2d5'  # bright cyan   → Teal
    printf '\e]PFcdd6f4'  # bright white  → Text
    clear
end

# --- Autostart ---
{{ if ne .primary_shell "bash" -}}
if status is-interactive
    and command -sq zellij
    and test -z "$ZELLIJ"
    and test "$MYCELIUM_AUTOSTART" != "0"
    and not set -q SSH_CONNECTION
    if test -f ~/.config/zellij/layouts/{{ .autostart_layout }}.kdl
        zellij -l {{ .autostart_layout }}; or true
    else
        zellij; or true
    end
end
{{ end -}}

# --- Theme ---
set -gx BAT_THEME "Catppuccin Mocha"
set -gx FZF_DEFAULT_OPTS "--color=bg+:#313244,bg:#1e1e2e,spinner:#f5e0dc,hl:#f38ba8 --color=fg:#cdd6f4,header:#f38ba8,info:#cba6f7,pointer:#f5e0dc --color=marker:#f5e0dc,fg+:#cdd6f4,prompt:#cba6f7,hl+:#f38ba8"
set -g fish_greeting

# --- Tool init ---
if command -sq zoxide
    zoxide init fish | source
end
if command -sq starship
    starship init fish | source
end
if command -sq fastfetch
    and status is-interactive
    and not set -q SSH_CONNECTION
    fastfetch
end

# --- Abbreviations ---
if command -sq eza
    abbr -a ls "eza --icons=never"
    abbr -a ll "eza -lah --icons=never"
    abbr -a la "eza -a --icons=never"
end
if command -sq bat
    abbr -a cat "bat --paging=never"
end

# --- Audio ---
abbr -a volup "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+"
abbr -a voldown "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"
abbr -a volmute "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
abbr -a audiostat "wpctl status"
